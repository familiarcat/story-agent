# Bayer Pharmaceutical - Patient-Centric Trial Management System (PCTMS)
# Copy this to .env and fill in with actual credentials

PROJECT_ID=bayer-pctms
PROJECT_NAME="Bayer Pharmaceutical - Patient-Centric Trial Management System"
PROJECT_TIER="gold-standard"
PROJECT_CREATED="2026-06-07"

# Supabase Configuration
# These are shared with ai-enterprise-os (same Supabase project)
SUPABASE_URL="https://sqachwmzyuuyyyxekdxp.supabase.co"
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Project-specific Database
PROJECT_DB_NAME="bayer_pctms"
PROJECT_DB_SCHEMA="public"
PROJECT_ORG_ID="bayer"

# GitHub Configuration
GITHUB_REPO="familiarcat/story-agent"
GITHUB_BRANCH="main"

# Client Information
CLIENT_NAME="Bayer Pharmaceutical Systems"
CLIENT_ORG_ID="bayer"
CLIENT_TIER="gold-standard"

# Compliance & Security
COMPLIANCE_MODE="phi"  # Protected Health Information
SECURITY_FRAMEWORK="worfgate"
ENCRYPTION_KEY_ID="worfgate-bayer-001"

# Crew Assignments
PRIMARY_CREW="picard,data,riker,geordi,obrien,worf"
SECONDARY_CREW="troi,crusher,uhura"
ADVISORY_CREW="quark,yar"

# Feature Flags
ENABLE_REAL_TIME=true
ENABLE_MIGRATIONS_AUTO=true
ENABLE_HEALTH_CHECKS=true
ENABLE_CREW_BASELINE=true
ENABLE_PERSONAL_MEMORIES=true

# Monitoring & Alerts
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
ALERT_SEVERITY_THRESHOLD="warning"
ALERT_CHANNELS="crew-alerts,ops-alerts"

# Performance Baselines
QUERY_LATENCY_P99_MS=100
QUERY_LATENCY_P95_MS=50
INDEX_HIT_RATIO_TARGET=0.95
CACHE_HIT_RATIO_TARGET=0.90

# Data Retention
DATA_RETENTION_DAYS=2555  # 7 years for HIPAA compliance
BACKUP_FREQUENCY="daily"
BACKUP_RETENTION_DAYS=90

# Audit & Compliance
AUDIT_LOGGING=true
RLS_ENFORCEMENT=true
ENCRYPTION_AT_REST=true
