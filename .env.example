# ── Agile Provider ─────────────────────────────────────────────────────────────
# Set AGILE_PROVIDER to one of: aha | jira | linear | github-projects | azure-devops
# If unset, auto-detected from which credentials are present; defaults to aha.
AGILE_PROVIDER=aha

# ── Aha (default) ──────────────────────────────────────────────────────────────
AHA_DOMAIN=your-domain.aha.io
AHA_API_KEY=your_aha_api_key_here

# ── Jira Cloud ─────────────────────────────────────────────────────────────────
# AGILE_PROVIDER=jira
# JIRA_DOMAIN=yourorg.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_atlassian_api_token

# ── Linear ─────────────────────────────────────────────────────────────────────
# AGILE_PROVIDER=linear
# LINEAR_API_KEY=your_linear_api_key

# ── GitHub Projects v2 ─────────────────────────────────────────────────────────
# AGILE_PROVIDER=github-projects
# GITHUB_ORG=your-github-org   (already set below; reuse GITHUB_TOKEN)

# ── Azure DevOps ───────────────────────────────────────────────────────────────
# AGILE_PROVIDER=azure-devops
# AZURE_DEVOPS_ORG=your-ado-org
# AZURE_DEVOPS_TOKEN=your_ado_personal_access_token

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_DEFAULT_ORG=your-github-org

# Supabase — shared with ai-enterprise-os (same project, sa_* tables)
# Copy values from ai-enterprise-os/.env
SUPABASE_URL=
SUPABASE_KEY=

# Redis (optional but recommended)
# Fast session memory cache + queue for async durable sync to Supabase
REDIS_URL=redis://127.0.0.1:6379

# Memory sync worker tuning
MEMORY_REDIS_RECENT_MAX=200
MEMORY_SYNC_BATCH_SIZE=50
MEMORY_SYNC_INTERVAL_MS=5000

# WorfGate security policy
# If true, inspect outbound payloads and memory transcripts for controlled markers
WORFGATE_ENFORCE=true
# If true, allow controlled markers to pass without blocking/redaction
WORFGATE_ALLOW_CONTROLLED=false
# Optional CSV override for marker detection (defaults built-in if unset)
# WORFGATE_CONTROLLED_MARKERS=bayer,confidential,internal use only,pii,phi
# Allowed GitHub orgs for controlled payload egress when WORFGATE_ALLOW_CONTROLLED=false
WORFGATE_ALLOWED_GITHUB_ORGS=familiarcat

# MCP Server
MCP_SERVER_PORT=3100

# Testing — Controls whether integration tests use real or mocked services
# TEST_ENV values:
#   local        = Use mocks/stubs (fast, no external deps, deterministic)
#   integration  = Real Supabase, real OpenRouter, real provider APIs
# Default: local (for local dev, run `pnpm run test:integration` to use real services)
TEST_ENV=local

# Next.js UI
NEXT_PUBLIC_MCP_URL=http://localhost:3100
