# Build outputs
packages/*/dist/
packages/*/.next/
dist/
*.tsbuildinfo

# Environment
.env
.env.local

# Dependencies
node_modules/
packages/*/node_modules/

# Logs
*.log

# OS
.DS_Store
Thumbs.db
Desktop.ini

# iCloud / cloud-sync conflict duplicates (e.g. "main 2", "route 2.ts") — never commit these.
* 2
* 2.*
*.icloud

# Terraform local state & providers (never commit)
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Bootstrap module local state (admin-only, never committed)
terraform/bootstrap/.terraform/
terraform/bootstrap/*.tfstate*
terraform/.terraform/

# delegation router runtime audit log
.claude/delegation-audit.jsonl
