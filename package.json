{
  "name": "story-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic story delivery system — MCP server + Next.js dashboard",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "dev": "concurrently --names MCP,UI --colors magenta,blue \"pnpm --filter @story-agent/mcp-server dev\" \"pnpm --filter @story-agent/ui dev\"",
    "prebuild": "node scripts/guard-build-vs-dev.mjs",
    "build": "pnpm --filter @story-agent/shared build && pnpm --filter @story-agent/mcp-server build && pnpm --filter @story-agent/ui build && pnpm --filter story-agent-vscode build",
    "start": "concurrently --names MCP,UI --colors magenta,blue \"pnpm --filter @story-agent/mcp-server start\" \"pnpm --filter @story-agent/ui start\"",
    "mcp": "pnpm --filter @story-agent/mcp-server dev",
    "ui": "pnpm --filter @story-agent/ui dev",
    "typecheck": "pnpm --filter @story-agent/shared build && pnpm --filter @story-agent/mcp-server typecheck && pnpm --filter @story-agent/ui typecheck && pnpm --filter story-agent-vscode typecheck",
    "lint": "pnpm --filter @story-agent/mcp-server lint --if-present && pnpm --filter @story-agent/ui lint --if-present",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm --filter @story-agent/shared test:unit && pnpm --filter @story-agent/mcp-server test:unit",
    "test:integration": "pnpm --filter @story-agent/shared test:integration && pnpm --filter @story-agent/mcp-server test:integration",
    "test:ci": "TEST_ENV=integration pnpm run test",
    "check": "pnpm run tokens:check && pnpm run typecheck && pnpm run build",
    "ext:package": "pnpm --filter story-agent-vscode package",
    "ext:install-local": "code --install-extension packages/vscode-extension/story-agent-vscode-1.0.0.vsix --force",
    "web:dev:clean": "rm -rf packages/ui/.next && pnpm --filter @story-agent/ui dev",
    "web:build-local": "pnpm --filter @story-agent/ui build",
    "web:start-local": "cd packages/ui && node_modules/.bin/next start -p 3000",
    "bridge:view": "pnpm run ui",
    "bridge:all": "pnpm --filter @story-agent/shared build && pnpm run crew:sync-ui && concurrently --names MCP,UI,MONITOR --colors magenta,blue,cyan \"pnpm run mcp\" \"pnpm run bridge:view\" \"npx ts-node scripts/list-all-stories.ts\"",
    "crew:sync-ui": "npx ts-node scripts/update-tool-ui-metadata.ts",
    "publish:local": "pnpm run web:build-local && pnpm run ext:package",
    "db:migrate": "node scripts/run-migrations-auto.mjs",
    "db:migrate:test": "node scripts/test-migrations.mjs",
    "db:auto-migrate": "node scripts/auto-migrate.mjs",
    "db:auto-migrate:dry": "node scripts/auto-migrate.mjs --dry-run",
    "db:health-check": "node scripts/db-health-check.mjs",
    "client:onboard": "node scripts/client-onboard.mjs",
    "crew:seed": "CREW_LLM_PROVIDER=demo pnpm --filter @story-agent/mcp-server exec node --input-type=module -e \"import { seedAllCrewSkillManifests } from './dist/src/lib/crew-skill-system.js'; await seedAllCrewSkillManifests(); console.log('✅ Crew skill manifests seeded');\"",
    "crew:seed-memories": "node scripts/seed-crew-memories.mjs",
    "crew:check": "CREW_LLM_PROVIDER=demo pnpm --filter @story-agent/mcp-server exec node --input-type=module -e \"import { generateCrewIntegrityReport } from './dist/src/lib/crew-integrity.js'; const report = await generateCrewIntegrityReport(); console.log(JSON.stringify(report, null, 2));\"",
    "docs:ingest": "npx tsx scripts/ingest-docs-to-rag.ts",
    "docs:ingest:dry": "npx tsx scripts/ingest-docs-to-rag.ts --dry-run",
    "docs:refresh": "pnpm run docs:ingest",
    "project:list": "node scripts/project-management.mjs list",
    "project:select": "node scripts/project-management.mjs select",
    "project:info": "node scripts/project-management.mjs info",
    "project:crew": "node scripts/project-management.mjs crew",
    "aws-secrets:put": "bash scripts/aws-secrets-put.sh",
    "aha:derive-backlog": "npx tsx scripts/derive-aha-backlog.ts",
    "aha:commit-backlog": "npx tsx scripts/aha-commit-backlog.ts",
    "db:push": "npx tsx scripts/worfgate-db-push.ts",
    "db:push:dry": "npx tsx scripts/worfgate-db-push.ts --dry-run",
    "tf": "npx tsx scripts/worfgate-terraform.ts",
    "tf:plan": "npx tsx scripts/worfgate-terraform.ts plan",
    "deploy:bootstrap-oidc": "bash scripts/bootstrap-oidc.sh",
    "deploy:backend": "bash scripts/setup-tf-backend.sh",
    "deploy:cleanup-orphans": "bash scripts/cleanup-orphaned-stack.sh",
    "deploy:cleanup-orphans:apply": "bash scripts/cleanup-orphaned-stack.sh --apply",
    "deploy:auto": "npx tsx scripts/deploy-auto.ts",
    "deploy:mission": "npx tsx scripts/deploy-automation-mission.ts",
    "activation:status": "npx tsx scripts/activation-status.ts",
    "tokens:build": "npx tsx scripts/build-tokens.ts",
    "tokens:check": "npx tsx scripts/build-tokens.ts --check",
    "lanes": "npx tsx scripts/control-lanes.ts",
    "lanes:json": "npx tsx scripts/control-lanes.ts --json",
    "figma:themes": "npx tsx scripts/figma-to-client-theme.ts",
    "figma:themes:dry": "npx tsx scripts/figma-to-client-theme.ts --dry-run",
    "activate": "npx tsx scripts/activate-changes.ts",
    "activate:full": "npx tsx scripts/activate-changes.ts --full"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "dotenv": "^16.4.7",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
