{
  "name": "@story-agent/shared",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./db": {
      "import": "./dist/src/db.js",
      "types": "./dist/src/db.d.ts"
    },
    "./client-security-policy": {
      "import": "./dist/src/client-security-policy.js",
      "types": "./dist/src/client-security-policy.d.ts"
    },
    "./client-registry": {
      "import": "./dist/src/client-registry.js",
      "types": "./dist/src/client-registry.d.ts"
    },
    "./worfgate-credentials": {
      "import": "./dist/src/worfgate-credentials.js",
      "types": "./dist/src/worfgate-credentials.d.ts"
    },
    "./worfgate-credential-providers": {
      "import": "./dist/src/worfgate-credential-providers.js",
      "types": "./dist/src/worfgate-credential-providers.d.ts"
    },
    "./skill-theory": {
      "import": "./dist/src/skill-theory.js",
      "types": "./dist/src/skill-theory.d.ts"
    },
    "./aha-credentials": {
      "import": "./dist/src/aha-credentials.js",
      "types": "./dist/src/aha-credentials.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:unit": "RUN_MODE=unit vitest run",
    "test:integration": "RUN_MODE=integration TEST_ENV=local vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@supabase/supabase-js": "^2.47.10",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
