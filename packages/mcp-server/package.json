{
  "name": "@story-agent/mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "story-agent-mcp": "./dist/src/index.js",
    "story-agent": "./dist/src/agent-core/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "concurrently --names TSC,NODE --colors cyan,magenta \"tsc -p tsconfig.build.json -w --preserveWatchOutput\" \"node --watch dist/src/index.js\"",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:unit": "RUN_MODE=unit vitest run",
    "test:integration": "RUN_MODE=integration TEST_ENV=local vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@story-agent/shared": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2",
    "openai": "^4.67.1",
    "pino": "^8.17.2",
    "ws": "^8.16.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
