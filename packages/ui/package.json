{
  "name": "@story-agent/ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --headed --project=chromium",
    "test:e2e:debug": "playwright test --debug --project=chromium",
    "validate:openapi-local-servers": "sh -c 'spec_url=${OPENAPI_URL:-http://localhost:3001/api/openapi}; body=$(curl -fsS \"$spec_url\"); echo \"$body\" | grep -q -- \"url: /api\" && ! echo \"$body\" | grep -q -- \"story-agent-alb\"'"
  },
  "dependencies": {
    "@story-agent/shared": "workspace:*",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.19",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
